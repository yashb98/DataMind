# DataMind Web — Local environment variables
# Copy to .env.local and fill in values

# Dashboard API service (mcp-visualization / dashboard-api)
NEXT_PUBLIC_DASHBOARD_API_URL=http://localhost:8110

# WebSocket URL for real-time dashboard updates
NEXT_PUBLIC_WS_URL=ws://localhost:8110

# Default tenant ID for development
NEXT_PUBLIC_TENANT_ID=default_tenant
